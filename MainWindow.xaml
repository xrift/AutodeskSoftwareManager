<Window x:Class="AutodeskSoftwareManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AutodeskSoftwareManager.Views"
        Title="Autodesk Software Manager"
        Height="820" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ContentBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- HEADER BAR                                              -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Border Width="28" Height="28" Background="{StaticResource AutodeskRedBrush}" CornerRadius="4">
                        <TextBlock Text="A" FontSize="16" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Autodesk Software Manager" Foreground="White" FontSize="13.5" FontWeight="SemiBold"/>
                        <TextBlock Text="LAN Fleet Management" Foreground="#8899BB" FontSize="10.5"/>
                    </StackPanel>
                </StackPanel>

                <!-- Global busy indicator (shown during scans/deployments) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Visibility="Collapsed" x:Name="BusyBar">
                    <TextBlock Text="Scanning network..." Foreground="#BDC3CE" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ProgressBar Width="200" Height="6" IsIndeterminate="True"
                                 Background="#3A4A6B" Foreground="{StaticResource AutodeskRedBrush}"/>
                    <Button Content="Cancel" Margin="12,0,0,0" Padding="10,4"
                            Style="{StaticResource ToolbarButtonStyle}" FontSize="11"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="v0.1.0.0" Foreground="#5A6A8A" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- MAIN AREA                                               -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource NavBgBrush}">
                <StackPanel>
                    <TextBlock Text="NAVIGATION" Foreground="#4A5A7A" FontSize="9.5" FontWeight="Bold"
                               Margin="16,18,0,8"/>

                    <RadioButton x:Name="NavComputers" Style="{StaticResource NavButtonStyle}"
                                 Tag="🖥" Content="Computers" IsChecked="True"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavInventory" Style="{StaticResource NavButtonStyle}"
                                 Tag="📦" Content="Inventory"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavDeploy" Style="{StaticResource NavButtonStyle}"
                                 Tag="🚀" Content="Deploy"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavPackages" Style="{StaticResource NavButtonStyle}"
                                 Tag="📋" Content="Packages"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavHistory" Style="{StaticResource NavButtonStyle}"
                                 Tag="🕒" Content="History"
                                 Checked="Nav_Checked"/>

                    <Separator Margin="16,12" Background="#2A3347"/>

                    <TextBlock Text="TOOLS" Foreground="#4A5A7A" FontSize="9.5" FontWeight="Bold"
                               Margin="16,0,0,8"/>

                    <RadioButton x:Name="NavSettings" Style="{StaticResource NavButtonStyle}"
                                 Tag="⚙" Content="Settings"
                                 Checked="Nav_Checked"/>

                    <!-- DB info badge -->
                    <Border Margin="12,24,12,0" Padding="10,8" CornerRadius="4" Background="#141C2A">
                        <StackPanel>
                            <TextBlock Text="DATABASE" Foreground="#4A5A7A" FontSize="9" FontWeight="Bold"/>
                            <TextBlock Text="manager.db" Foreground="#6A7A9A" FontSize="10.5" Margin="0,3,0,0"/>
                            <TextBlock Text="324 computers  ·  1,847 records"
                                       Foreground="#4A5A7A" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Content panel — one view visible at a time -->
            <Grid Grid.Column="1" Background="{StaticResource ContentBgBrush}">
                <views:ComputersView  x:Name="ViewComputers"  Visibility="Visible"/>
                <views:InventoryView  x:Name="ViewInventory"  Visibility="Collapsed"/>
                <views:DeployView     x:Name="ViewDeploy"     Visibility="Collapsed"/>
                <views:PackagesView   x:Name="ViewPackages"   Visibility="Collapsed"/>
                <views:HistoryView    x:Name="ViewHistory"    Visibility="Collapsed"/>
                <views:SettingsView   x:Name="ViewSettings"   Visibility="Collapsed"/>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                              -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource StatusBarBgBrush}">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Ready  ·  Last scan: 2026-04-26  08:32 AM"
                           Foreground="#5A6A8A" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource OnlineBrush}" Margin="0,0,5,0"/>
                    <TextBlock Text="287 online" Foreground="#5A6A8A" FontSize="11"/>
                    <TextBlock Text=" / 324 total" Foreground="#3A4A6A" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
