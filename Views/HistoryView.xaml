<UserControl x:Class="AutodeskSoftwareManager.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="📊  Export CSV" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="🔄  Refresh" Style="{StaticResource ToolbarButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1" Background="White" Padding="14,8" Margin="14,12,14,0"
                CornerRadius="6" BorderBrush="#E8E8E8" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555" FontSize="12"/>
                <ComboBox Height="28" FontSize="12" MinWidth="160" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem>All Packages</ComboBoxItem>
                    <ComboBoxItem>AutoCAD 2025 Update 1</ComboBoxItem>
                    <ComboBoxItem>Revit 2025 Update 2</ComboBoxItem>
                </ComboBox>
                <ComboBox Height="28" FontSize="12" MinWidth="130" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem>All Results</ComboBoxItem>
                    <ComboBoxItem>Success only</ComboBoxItem>
                    <ComboBoxItem>Failed only</ComboBoxItem>
                </ComboBox>
                <TextBox Width="160" Height="28" FontSize="12" Padding="6,0" VerticalContentAlignment="Center"
                         BorderBrush="#CCC" Margin="0,0,10,0" Text=""/>
                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" Foreground="#555"/>
                <DatePicker Height="28" FontSize="11" Width="120" Margin="0,0,10,0"/>
                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" Foreground="#555"/>
                <DatePicker Height="28" FontSize="11" Width="120"/>
            </StackPanel>
        </Border>

        <!-- History DataGrid -->
        <DataGrid x:Name="HistoryGrid" Grid.Row="2" Style="{StaticResource MainGridStyle}" Margin="14,8,14,14">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Success}" Value="False">
                            <Setter Property="Background" Value="#FFF5F5"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Started" Width="140" Binding="{Binding Started}"/>
                <DataGridTextColumn Header="Computer" Width="150" Binding="{Binding Computer}"/>
                <DataGridTextColumn Header="OU" Width="120" Binding="{Binding OU}"/>
                <DataGridTextColumn Header="Package" Width="200" Binding="{Binding Package}"/>
                <DataGridTextColumn Header="Target Version" Width="115" Binding="{Binding TargetVersion}"/>
                <DataGridTemplateColumn Header="Result" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="7,2" HorizontalAlignment="Left"
                                    VerticalAlignment="Center" Margin="4,0"
                                    Background="{Binding ResultColor}">
                                <TextBlock Text="{Binding ResultText}" Foreground="White" FontSize="10.5" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Duration" Width="80" Binding="{Binding Duration}"/>
                <DataGridTextColumn Header="Message" Width="*" Binding="{Binding Message}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
