<UserControl x:Class="AutodeskSoftwareManager.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="📊  Export CSV"
                        Command="{Binding ExportCsvCommand}"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="🔄  Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1" Background="White" Padding="14,8" Margin="14,12,14,0"
                CornerRadius="6" BorderBrush="#E8E8E8" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555" FontSize="12"/>
                <TextBox Width="160" Height="28" FontSize="12" Padding="6,0"
                         VerticalContentAlignment="Center" BorderBrush="#CCC" Margin="0,0,10,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <ComboBox Height="28" FontSize="12" MinWidth="200" Margin="0,0,10,0"
                          ItemsSource="{Binding PackageNames}"
                          SelectedItem="{Binding SelectedPackage}"/>
                <ComboBox Height="28" FontSize="12" MinWidth="120" Margin="0,0,10,0"
                          SelectedValue="{Binding SelectedResult}" SelectedValuePath="Content">
                    <ComboBoxItem Content="All"     IsSelected="True"/>
                    <ComboBoxItem Content="Success"/>
                    <ComboBoxItem Content="Failed"/>
                </ComboBox>
                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" Foreground="#555"/>
                <DatePicker Height="28" Width="120" Margin="0,0,10,0"
                            SelectedDate="{Binding DateFrom}"/>
                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" Foreground="#555"/>
                <DatePicker Height="28" Width="120"
                            SelectedDate="{Binding DateTo}"/>
            </StackPanel>
        </Border>

        <!-- History grid -->
        <DataGrid Grid.Row="2" Style="{StaticResource MainGridStyle}"
                  Margin="14,8,14,14"
                  ItemsSource="{Binding HistoryView}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Success}" Value="False">
                            <Setter Property="Background" Value="#FFF5F5"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Started"        Width="140" Binding="{Binding StartedAtDisplay}"/>
                <DataGridTextColumn Header="Computer"       Width="150" Binding="{Binding ComputerName}"/>
                <DataGridTextColumn Header="OU"             Width="110" Binding="{Binding ComputerOU}"/>
                <DataGridTextColumn Header="Package"        Width="200" Binding="{Binding PackageName}"/>
                <DataGridTextColumn Header="Target Version" Width="115" Binding="{Binding TargetVersion}"/>
                <DataGridTemplateColumn Header="Result" Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="7,2" Margin="4,0"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{Binding ResultColor}">
                                <TextBlock Text="{Binding ResultText}" Foreground="White"
                                           FontSize="10.5" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Duration" Width="80"  Binding="{Binding DurationDisplay}"/>
                <DataGridTextColumn Header="Message"  Width="*"   Binding="{Binding Message}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
