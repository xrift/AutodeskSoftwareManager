<UserControl x:Class="AutodeskSoftwareManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24" MaxWidth="680" HorizontalAlignment="Left">

            <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Foreground="#2C3547" Margin="0,0,0,20"/>

            <!-- Scanning section -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="NETWORK SCANNING" Style="{StaticResource SectionHeaderStyle}"
                               FontSize="10.5" Foreground="#888" Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Max scan threads" FontSize="12.5" Foreground="#333"/>
                            <TextBlock Text="Parallel WMI connections during inventory scan" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Slider Minimum="1" Maximum="50" Value="20" Width="160" HorizontalAlignment="Left"
                                    TickFrequency="5" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="20 threads" FontSize="11" Foreground="#555" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ping timeout (ms)" FontSize="12.5" Foreground="#333"/>
                            <TextBlock Text="Per-host ping timeout before marking offline" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" Width="100" Height="30" FontSize="12" Padding="8,4"
                                 BorderBrush="#CCC" Text="1500" HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="AD computer filter (LDAP)" FontSize="12.5" Foreground="#333"/>
                            <TextBlock Text="Filter applied when querying Active Directory" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" Height="30" FontSize="11" FontFamily="Consolas" Padding="8,4"
                                 BorderBrush="#CCC" VerticalContentAlignment="Center"
                                 Text="(&amp;(objectCategory=computer)(operatingSystem=Windows*))"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Deployment section -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="DEPLOYMENT" Style="{StaticResource SectionHeaderStyle}"
                               FontSize="10.5" Foreground="#888" Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Max deploy threads" FontSize="12.5" Foreground="#333"/>
                            <TextBlock Text="Parallel simultaneous deployments" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Slider Minimum="1" Maximum="20" Value="10" Width="160" HorizontalAlignment="Left"
                                    TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="10 threads" FontSize="11" Foreground="#555" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Deploy timeout (seconds)" FontSize="12.5" Foreground="#333"/>
                            <TextBlock Text="Max wait per installer before marking failed" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" Width="100" Height="30" FontSize="12" Padding="8,4"
                                 BorderBrush="#CCC" Text="300" HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Default silent args" FontSize="12.5" Foreground="#333"/>
                            <TextBlock Text="Pre-filled when adding a new package" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" Height="30" Width="220" FontSize="12" FontFamily="Consolas"
                                 Padding="8,4" BorderBrush="#CCC" HorizontalAlignment="Left"
                                 VerticalContentAlignment="Center" Text="/qn /norestart"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Database section -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="DATABASE" Style="{StaticResource SectionHeaderStyle}"
                               FontSize="10.5" Foreground="#888" Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Database file path" FontSize="12.5" Foreground="#333"/>
                            <TextBlock Text="SQLite database location" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Height="30" FontSize="11" Padding="8,4"
                                         BorderBrush="#CCC" VerticalContentAlignment="Center"
                                         Text="%APPDATA%\AutodeskSoftwareManager\manager.db"/>
                                <Button Grid.Column="1" Content="Browse" Style="{StaticResource ToolbarButtonStyle}"
                                        Margin="6,0,0,0" FontSize="11" Padding="8,4"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open DB Folder" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0" FontSize="11"/>
                        <Button Content="Backup DB" Style="{StaticResource ToolbarButtonStyle}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About section -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ABOUT" Style="{StaticResource SectionHeaderStyle}"
                               FontSize="10.5" Foreground="#888" Margin="0,0,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Application:" FontSize="12" Foreground="#888"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Autodesk Software Manager" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Version:" FontSize="12" Foreground="#888" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="0.1.0.0" FontSize="12" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Framework:" FontSize="12" Foreground="#888" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text=".NET 9 / WPF / SQLite" FontSize="12" Margin="0,6,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save button -->
            <StackPanel Orientation="Horizontal">
                <Button Content="💾  Save Settings" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Reset to Defaults" Style="{StaticResource ToolbarButtonStyle}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
