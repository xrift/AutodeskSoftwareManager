<UserControl x:Class="AutodeskSoftwareManager.Views.DeployView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="🚀  Deploy to Selected"
                        Command="{Binding DeployCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="☑  Select All Outdated"
                        Command="{Binding SelectAllOutdatedCommand}"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="☐  Clear Selection"
                        Command="{Binding ClearSelectionCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="14,14,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Package list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="DEPLOYMENT PACKAGE" FontSize="10.5"
                           FontWeight="Bold" Foreground="#888" Margin="0,0,0,8"/>

                <Border Grid.Row="1" Background="White" CornerRadius="6"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <ListBox ItemsSource="{Binding Packages}"
                             SelectedItem="{Binding SelectedPackage}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"         Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush"     Value="#F0F0F0"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"          FontWeight="SemiBold" FontSize="12.5" Foreground="#2C3547"/>
                                    <TextBlock Text="{Binding ProductFamily}"  FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding TargetVersion}"  FontSize="11" Foreground="{StaticResource AutodeskRedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Summary card -->
                <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="12"
                        Margin="0,10,0,0" BorderBrush="#E0E0E0" BorderThickness="1"
                        Visibility="{Binding SelectedPackage, Converter={StaticResource NullToVis}}">
                    <StackPanel>
                        <TextBlock Text="SELECTED PACKAGE" FontSize="9.5" FontWeight="Bold" Foreground="#888" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Package:" FontSize="11" Foreground="#888"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPackage.Name}"
                                       FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Version:"  FontSize="11" Foreground="#888" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPackage.TargetVersion}"
                                       FontSize="11" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Args:"    FontSize="11" Foreground="#888" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedPackage.SilentArgs}"
                                       FontSize="11" FontFamily="Consolas" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Target computers -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="TARGET COMPUTERS" FontSize="10.5"
                           FontWeight="Bold" Foreground="#888" Margin="0,0,0,8"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <ComboBox Height="28" FontSize="12" MinWidth="160" Margin="0,0,10,0"
                              SelectedValue="{Binding TargetFilter}" SelectedValuePath="Content">
                        <ComboBoxItem Content="Outdated only"  IsSelected="True"/>
                        <ComboBoxItem Content="All online"/>
                        <ComboBoxItem Content="Not installed"/>
                    </ComboBox>
                </StackPanel>

                <DataGrid Grid.Row="2" Style="{StaticResource MainGridStyle}"
                          ItemsSource="{Binding Targets}">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOutdated}" Value="True">
                                    <Setter Property="Background" Value="#FFF8F0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Width="36" Header=""
                                                Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="Computer"        Width="150" Binding="{Binding ComputerName}"/>
                        <DataGridTextColumn Header="OU"              Width="110" Binding="{Binding OU}"/>
                        <DataGridTextColumn Header="Current Version" Width="125" Binding="{Binding CurrentVersion}"/>
                        <DataGridTextColumn Header="Target Version"  Width="115" Binding="{Binding TargetVersion}"/>
                        <DataGridTemplateColumn Header="Status" Width="115">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="7,2" Margin="4,0"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Background="{Binding StatusColor}">
                                        <TextBlock Text="{Binding StatusText}" Foreground="White"
                                                   FontSize="10.5" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Logged-in User" Width="120" Binding="{Binding LoggedInUser}"/>
                        <DataGridTextColumn Header="Last Deploy"     Width="*"   Binding="{Binding LastDeploy}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Progress panel -->
        <Border Grid.Row="2" Background="White" Padding="14,10" Margin="14,0,14,14"
                CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding ProgressText}" FontSize="12" Foreground="#555" Margin="0,0,0,5"/>
                    <ProgressBar Height="6" Value="{Binding ProgressValue}" Maximum="100"
                                 Background="#E0E0E0" Foreground="{StaticResource AutodeskRedBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
