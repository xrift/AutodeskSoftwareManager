<UserControl x:Class="AutodeskSoftwareManager.Views.DeployView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="🚀  Deploy to Selected" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="☑  Select All Outdated" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="☐  Clear Selection" Style="{StaticResource ToolbarButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Main split: package picker (left) + target grid (right) -->
        <Grid Grid.Row="1" Margin="14,14,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Package panel -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="DEPLOYMENT PACKAGE" Style="{StaticResource SectionHeaderStyle}"
                           FontSize="10.5" Foreground="#888" Margin="0,0,0,8"/>

                <Border Grid.Row="1" Background="White" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1">
                    <ListBox x:Name="PackageList" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F0F0F0"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12.5" Foreground="#2C3547"/>
                                    <TextBlock Text="{Binding ProductFamily}" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Version}" FontSize="11" Foreground="{StaticResource AutodeskRedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Selected package detail -->
                <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="12" Margin="0,10,0,0"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="SELECTED PACKAGE" FontSize="9.5" FontWeight="Bold" Foreground="#888" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Package:" FontSize="11" Foreground="#888"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="AutoCAD 2025 Update 1" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Version:" FontSize="11" Foreground="#888" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="25.1.0.0" FontSize="11" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Args:" FontSize="11" Foreground="#888" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="/qn /norestart" FontSize="11" FontFamily="Consolas" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Targets:" FontSize="11" Foreground="#888" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="3 selected (all outdated)" FontSize="11" Foreground="{StaticResource AutodeskRedBrush}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Right: Target computers -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="TARGET COMPUTERS" Style="{StaticResource SectionHeaderStyle}"
                           FontSize="10.5" Foreground="#888" Margin="0,0,0,8"/>

                <!-- Filter -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <ComboBox Height="28" FontSize="12" MinWidth="160" Margin="0,0,10,0" SelectedIndex="1">
                        <ComboBoxItem>All computers</ComboBoxItem>
                        <ComboBoxItem>Outdated only</ComboBoxItem>
                        <ComboBoxItem>Not installed</ComboBoxItem>
                    </ComboBox>
                    <ComboBox Height="28" FontSize="12" MinWidth="130" SelectedIndex="0">
                        <ComboBoxItem>All OUs</ComboBoxItem>
                        <ComboBoxItem>ENGINEERING</ComboBoxItem>
                        <ComboBoxItem>ARCHITECTURE</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <DataGrid x:Name="DeployGrid" Grid.Row="2" Style="{StaticResource MainGridStyle}">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOutdated}" Value="True">
                                    <Setter Property="Background" Value="#FFF8F0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Width="36" Header="" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="Computer" Width="150" Binding="{Binding Computer}"/>
                        <DataGridTextColumn Header="OU" Width="120" Binding="{Binding OU}"/>
                        <DataGridTextColumn Header="Current Version" Width="130" Binding="{Binding CurrentVersion}"/>
                        <DataGridTextColumn Header="Target Version" Width="120" Binding="{Binding TargetVersion}"/>
                        <DataGridTemplateColumn Header="Status" Width="115">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="7,2" HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Margin="4,0"
                                            Background="{Binding StatusColor}">
                                        <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="10.5" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Logged-in User" Width="120" Binding="{Binding LoggedInUser}"/>
                        <DataGridTextColumn Header="Last Deploy" Width="*" Binding="{Binding LastDeploy}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Bottom: progress area -->
        <Border Grid.Row="2" Background="White" Padding="14,10" Margin="14,0,14,14"
                CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ENG-WS-001 — Copying installer...   ENG-WS-003 — Launching installer...   ENG-WS-002 — Waiting for process..."
                               FontSize="11.5" Foreground="#555" Margin="0,0,0,6"/>
                    <ProgressBar Height="6" Value="33" Maximum="100"
                                 Background="#E0E0E0" Foreground="{StaticResource AutodeskRedBrush}"/>
                    <TextBlock Text="Deploying to 3 computers — 1 / 3 complete" FontSize="11" Foreground="#888" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Cancel" Style="{StaticResource ToolbarButtonStyle}"
                        Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
