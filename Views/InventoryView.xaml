<UserControl x:Class="AutodeskSoftwareManager.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="📥  Scan Selected" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="📥  Scan All Online" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
                <Separator Width="1" Background="#DDD" Margin="6,2"/>
                <Button Content="📊  Export CSV" Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,8,0"/>
                <Button Content="🔄  Refresh" Style="{StaticResource ToolbarButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Stat cards -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="14,12,14,4">
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="1,847" Style="{StaticResource StatNumberStyle}"/>
                    <TextBlock Text="Total Installations" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="18" Style="{StaticResource StatNumberStyle}" Foreground="#3A4A6B"/>
                    <TextBlock Text="Distinct Products" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="54" Style="{StaticResource StatNumberStyle}" Foreground="{StaticResource OutdatedBrush}"/>
                    <TextBlock Text="Outdated" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="1,793" Style="{StaticResource StatNumberStyle}" Foreground="{StaticResource UpToDateBrush}"/>
                    <TextBlock Text="Up to Date" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="33" Style="{StaticResource StatNumberStyle}" Foreground="{StaticResource UnknownBrush}"/>
                    <TextBlock Text="Unknown Version" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Filter bar -->
        <Border Grid.Row="2" Background="White" Padding="14,8" Margin="14,4,14,0"
                CornerRadius="6" BorderBrush="#E8E8E8" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555" FontSize="12"/>
                <TextBox Width="180" Height="28" FontSize="12" Padding="6,0" VerticalContentAlignment="Center"
                         BorderBrush="#CCC" Margin="0,0,10,0"/>
                <ComboBox Height="28" FontSize="12" MinWidth="160" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem>All Products</ComboBoxItem>
                    <ComboBoxItem>AutoCAD</ComboBoxItem>
                    <ComboBoxItem>Revit</ComboBoxItem>
                    <ComboBoxItem>Inventor</ComboBoxItem>
                    <ComboBoxItem>Civil 3D</ComboBoxItem>
                    <ComboBoxItem>3ds Max</ComboBoxItem>
                    <ComboBoxItem>Maya</ComboBoxItem>
                    <ComboBoxItem>Navisworks</ComboBoxItem>
                    <ComboBoxItem>Fusion 360</ComboBoxItem>
                </ComboBox>
                <ComboBox Height="28" FontSize="12" MinWidth="130" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem>All Years</ComboBoxItem>
                    <ComboBoxItem>2026</ComboBoxItem>
                    <ComboBoxItem>2025</ComboBoxItem>
                    <ComboBoxItem>2024</ComboBoxItem>
                    <ComboBoxItem>2023</ComboBoxItem>
                </ComboBox>
                <ComboBox Height="28" FontSize="12" MinWidth="130" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem>All Status</ComboBoxItem>
                    <ComboBoxItem>Outdated only</ComboBoxItem>
                    <ComboBoxItem>Up to date</ComboBoxItem>
                    <ComboBoxItem>Unknown version</ComboBoxItem>
                </ComboBox>
                <ComboBox Height="28" FontSize="12" MinWidth="130" SelectedIndex="0">
                    <ComboBoxItem>All OUs</ComboBoxItem>
                    <ComboBoxItem>ENGINEERING</ComboBoxItem>
                    <ComboBoxItem>ARCHITECTURE</ComboBoxItem>
                    <ComboBoxItem>DESIGN</ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Inventory DataGrid -->
        <DataGrid x:Name="InventoryGrid" Grid.Row="3" Style="{StaticResource MainGridStyle}" Margin="14,8,14,14">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOutdated}" Value="True">
                            <Setter Property="Background" Value="#FFF8F0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Computer" Width="150" Binding="{Binding Computer}"/>
                <DataGridTextColumn Header="OU" Width="120" Binding="{Binding OU}"/>
                <DataGridTextColumn Header="Product" Width="175" Binding="{Binding Product}"/>
                <DataGridTextColumn Header="Year" Width="55" Binding="{Binding Year}"/>
                <DataGridTextColumn Header="Installed Version" Width="130" Binding="{Binding InstalledVersion}"/>
                <DataGridTextColumn Header="Latest Version" Width="130" Binding="{Binding LatestVersion}"/>
                <DataGridTemplateColumn Header="Status" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="7,2" HorizontalAlignment="Left"
                                    VerticalAlignment="Center" Margin="4,0"
                                    Background="{Binding StatusColor}">
                                <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="10.5" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Install Date" Width="100" Binding="{Binding InstallDate}"/>
                <DataGridTextColumn Header="Scanned" Width="135" Binding="{Binding ScannedAt}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
