<Window x:Class="AutodeskSoftwareManager.Views.AddComputerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Computer" Height="180" Width="380"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#F4F5F7">
    <StackPanel Margin="20">
        <TextBlock Text="Computer name or hostname:" FontSize="12.5" Foreground="#333" Margin="0,0,0,6"/>
        <TextBox x:Name="NameBox" Height="32" FontSize="13" Padding="8,4"
                 BorderBrush="#CCC" VerticalContentAlignment="Center"
                 KeyDown="NameBox_KeyDown"/>
        <TextBlock x:Name="ErrorText" Foreground="#E74C3C" FontSize="11.5"
                   Margin="0,6,0,0" Visibility="Collapsed"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OkBtn" Content="Add" Width="80" Height="30"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"
                    Click="Ok_Click"/>
            <Button Content="Cancel" Width="80" Height="30"
                    Style="{StaticResource ToolbarButtonStyle}"
                    IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
