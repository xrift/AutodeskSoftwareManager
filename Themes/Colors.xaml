<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand -->
    <Color x:Key="AutodeskRedColor">#E84242</Color>
    <Color x:Key="NavBgColor">#1E2430</Color>
    <Color x:Key="NavHoverColor">#2A3347</Color>
    <Color x:Key="NavSelectedColor">#3A4A6B</Color>
    <Color x:Key="NavBorderColor">#E84242</Color>
    <Color x:Key="ContentBgColor">#F4F5F7</Color>
    <Color x:Key="CardBgColor">#FFFFFF</Color>
    <Color x:Key="HeaderBgColor">#2C3547</Color>
    <Color x:Key="StatusBarBgColor">#1E2430</Color>

    <!-- Status colors -->
    <Color x:Key="OnlineColor">#27AE60</Color>
    <Color x:Key="OfflineColor">#E74C3C</Color>
    <Color x:Key="WarningColor">#F39C12</Color>
    <Color x:Key="OutdatedColor">#E67E22</Color>
    <Color x:Key="UpToDateColor">#27AE60</Color>
    <Color x:Key="UnknownColor">#95A5A6</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AutodeskRedBrush" Color="{StaticResource AutodeskRedColor}"/>
    <SolidColorBrush x:Key="NavBgBrush" Color="{StaticResource NavBgColor}"/>
    <SolidColorBrush x:Key="NavHoverBrush" Color="{StaticResource NavHoverColor}"/>
    <SolidColorBrush x:Key="NavSelectedBrush" Color="{StaticResource NavSelectedColor}"/>
    <SolidColorBrush x:Key="NavBorderBrush" Color="{StaticResource NavBorderColor}"/>
    <SolidColorBrush x:Key="ContentBgBrush" Color="{StaticResource ContentBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="HeaderBgBrush" Color="{StaticResource HeaderBgColor}"/>
    <SolidColorBrush x:Key="StatusBarBgBrush" Color="{StaticResource StatusBarBgColor}"/>

    <SolidColorBrush x:Key="OnlineBrush" Color="{StaticResource OnlineColor}"/>
    <SolidColorBrush x:Key="OfflineBrush" Color="{StaticResource OfflineColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="OutdatedBrush" Color="{StaticResource OutdatedColor}"/>
    <SolidColorBrush x:Key="UpToDateBrush" Color="{StaticResource UpToDateColor}"/>
    <SolidColorBrush x:Key="UnknownBrush" Color="{StaticResource UnknownColor}"/>

</ResourceDictionary>
